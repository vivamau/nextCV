{
  "name": "nextcv-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "import": "node scripts/importCvs.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "ollama": "^0.6.3",
    "sqlite3": "^6.0.1",
    "vectordb": "^0.21.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "services/**/*.js",
      "routes/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 85,
        "functions": 85,
        "branches": 85
      }
    }
  }
}
